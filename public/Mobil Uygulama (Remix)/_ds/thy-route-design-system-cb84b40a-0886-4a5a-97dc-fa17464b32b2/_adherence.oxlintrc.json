{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/travel/**",
              "ui_kits/booking_portal/**",
              "ui_kits/cockpit/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Outfit|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Outfit, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:status|gold|outbound|inbound|red|mono)$/]",
        "message": "<Badge> variant must be one of 'status' | 'gold' | 'outbound' | 'inbound' | 'red' | 'mono'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BoardingPass'] > JSXAttribute > JSXIdentifier[name!=/^(?:flightCode|fromCode|toCode|fromCity|toCity|style|key|ref|className|style|children)$/]",
        "message": "<BoardingPass> doesn't accept that prop. Declared props: flightCode, fromCode, toCode, fromCity, toCity, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|gold|search)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'gold' | 'search'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:glass|solid|light)$/]",
        "message": "<Card> variant must be one of 'glass' | 'solid' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|icon|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Fare'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|color|key|ref|className|style|children)$/]",
        "message": "<Fare> doesn't accept that prop. Declared props: name, price, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|mono|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, mono, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='PartnerItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|offer|icon|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<PartnerItem> doesn't accept that prop. Declared props: name, offer, icon, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|icon|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: type, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:success|error|info)$/]",
        "message": "<Toast> type must be one of 'success' | 'error' | 'info'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
