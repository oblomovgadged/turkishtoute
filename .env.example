# Environment variables — copy this to `.env.local` and fill in real values.
# .env.local is git-ignored. Never commit secrets.

# ---- Firebase ----
# Get these from: https://console.firebase.google.com → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- EmailJS ----
# Get from: https://dashboard.emailjs.com
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# ---- Google Maps ----
# Get from: https://console.cloud.google.com → APIs & Services
VITE_GOOGLE_MAPS_KEY=

# ---- Flight API ----
# Your THY API endpoint (or a proxy serverless function on Vercel)
VITE_FLIGHTS_ENDPOINT=/api/flights
